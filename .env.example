# Never commit real values. Use a newly issued mock-trading key pair.
GH_ACCOUNT=12345678-01
GH_APPKEY=replace_with_mock_app_key
GH_APPSECRET=replace_with_mock_app_secret

# Conservative defaults for the Korea Investment mock environment.
POLL_INTERVAL_SECONDS=180
MONITOR_INTERVAL_SECONDS=180
VERIFICATION_DELAY_SECONDS=30
PRICE_OFFSET_KRW=1000
PRICE_TICK_KRW=100
ORDER_QUANTITY=3
# 0 means no daily cycle limit; only one active pair is allowed at a time.
MAX_ORDER_PAIRS_PER_DAY=0
REQUEST_MIN_INTERVAL_SECONDS=0.6
